{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.json-database.local/document.schema.json",
  "title": "JSON Database Stored Document",
  "description": "A stored document object. The database adds a non-empty string id and reserves __jsondb_type__ for internal serialized values.",
  "type": "object",
  "required": ["id"],
  "propertyNames": {
    "not": { "const": "__jsondb_type__" }
  },
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Document id generated by insert() or supplied to replace()/upsert()."
    }
  },
  "additionalProperties": {
    "$ref": "#/$defs/jsondbValue"
  },
  "$defs": {
    "jsondbValue": {
      "oneOf": [
        { "type": "null" },
        { "type": "boolean" },
        { "type": "string" },
        { "type": "number" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/jsondbValue" }
        },
        { "$ref": "#/$defs/jsondbObject" },
        { "$ref": "#/$defs/taggedValue" }
      ]
    },
    "jsondbObject": {
      "type": "object",
      "propertyNames": {
        "not": { "const": "__jsondb_type__" }
      },
      "additionalProperties": {
        "$ref": "#/$defs/jsondbValue"
      }
    },
    "taggedValue": {
      "oneOf": [
        { "$ref": "#/$defs/taggedDateTime" },
        { "$ref": "#/$defs/taggedDate" },
        { "$ref": "#/$defs/taggedDecimal" },
        { "$ref": "#/$defs/taggedBytes" },
        { "$ref": "#/$defs/taggedSet" }
      ]
    },
    "taggedDateTime": {
      "type": "object",
      "required": ["__jsondb_type__", "value"],
      "properties": {
        "__jsondb_type__": { "const": "datetime" },
        "value": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "taggedDate": {
      "type": "object",
      "required": ["__jsondb_type__", "value"],
      "properties": {
        "__jsondb_type__": { "const": "date" },
        "value": { "type": "string", "format": "date" }
      },
      "additionalProperties": false
    },
    "taggedDecimal": {
      "type": "object",
      "required": ["__jsondb_type__", "value"],
      "properties": {
        "__jsondb_type__": { "const": "decimal" },
        "value": {
          "type": "string",
          "pattern": "^[+-]?(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?$"
        }
      },
      "additionalProperties": false
    },
    "taggedBytes": {
      "type": "object",
      "required": ["__jsondb_type__", "value"],
      "properties": {
        "__jsondb_type__": { "const": "bytes" },
        "value": {
          "type": "string",
          "contentEncoding": "base64"
        }
      },
      "additionalProperties": false
    },
    "taggedSet": {
      "type": "object",
      "required": ["__jsondb_type__", "value"],
      "properties": {
        "__jsondb_type__": { "const": "set" },
        "value": {
          "type": "array",
          "items": { "$ref": "#/$defs/jsondbValue" }
        }
      },
      "additionalProperties": false
    }
  }
}
